%% Diagram arsitektur pipeline GempaWas (Mermaid source)
%% Render dengan: mermaid-cli (mmdc -i file.mmd -o out.svg) atau VS Code preview

flowchart TB
    subgraph SRC["1. EXTERNAL DATA SOURCES"]
        USGS["USGS Earthquake API<br/>earthquake.usgs.gov<br/>GeoJSON • global"]
        BMKG["BMKG Open API<br/>data.bmkg.go.id<br/>JSON • Indonesia"]
    end

    subgraph ING["2. INGESTION • GitHub Actions cron hourly"]
        CRON["scheduled_ingestion.yml<br/>cron: 5 * * * *"]
        INGPY["src/ingestion.py<br/>fetch + normalize + dedup"]
        PREPY["src/preprocess.py<br/>cleaning + outlier removal"]
        QDRIFT["Quick drift check<br/>src/monitor.py — PSI"]
    end

    subgraph STORE["3. STORAGE — DVC tracked"]
        RAW["data/raw/<br/>*.json snapshot"]
        DB["data/gempa.db<br/>SQLite operational"]
        INTERIM["data/interim/<br/>events_clean.parquet"]
        PROC["data/processed/<br/>features.parquet<br/>(versioned: data-v0.1 ...)"]
    end

    subgraph FE["4. FEATURE ENGINEERING"]
        MS["Identifikasi mainshock<br/>M ≥ 5, isolated 7d/100km"]
        ROLL["Rolling features<br/>count/max_mag 1,6,24 jam"]
        LAB["Compute label<br/>susulan ≥ M4 dalam 24 jam"]
    end

    subgraph TRAIN["5. TRAINING — XGBoost + MLflow"]
        WCRON["weekly_retrain.yml<br/>cron: 0 3 * * 1"]
        TRPY["src/train.py<br/>XGBoost time-split"]
        MLF["MLflow Tracking<br/>params, metrics, model"]
        REG["MLflow Registry<br/>None → Staging → Production"]
    end

    subgraph SERVE["6. SERVING"]
        API["FastAPI :8000<br/>POST /predict"]
        ST["Streamlit :8501<br/>dashboard BPBD"]
        DOCK["Docker container<br/>deploy-ready"]
    end

    subgraph USERS["7. END USERS"]
        BPBD[BPBD Provinsi]
        BNPB[BNPB]
        MEDIA[Media massa]
        APP[App warga]
        INS[Asuransi]
    end

    USGS --> INGPY
    BMKG --> INGPY
    CRON --> INGPY
    INGPY --> RAW
    INGPY --> DB
    DB --> PREPY
    PREPY --> INTERIM
    INTERIM --> MS
    MS --> ROLL
    ROLL --> LAB
    LAB --> PROC
    PROC --> TRPY
    WCRON --> TRPY
    TRPY --> MLF
    MLF --> REG
    REG --> API
    REG --> ST
    REG --> DOCK
    API --> BPBD
    API --> APP
    API --> INS
    ST --> BPBD
    ST --> BNPB
    API --> MEDIA

    QDRIFT -.->|PSI ≥ 0.1| WCRON
    INGPY --> QDRIFT
    DB -.-> QDRIFT

    classDef src fill:#fef3c7,stroke:#f59e0b
    classDef ingest fill:#dbeafe,stroke:#3b82f6
    classDef store fill:#dcfce7,stroke:#16a34a
    classDef fe fill:#ede9fe,stroke:#7c3aed
    classDef train fill:#fee2e2,stroke:#dc2626
    classDef serve fill:#cffafe,stroke:#0891b2
    classDef user fill:#f3f4f6,stroke:#374151

    class USGS,BMKG src
    class CRON,INGPY,PREPY,QDRIFT ingest
    class RAW,DB,INTERIM,PROC store
    class MS,ROLL,LAB fe
    class WCRON,TRPY,MLF,REG train
    class API,ST,DOCK serve
    class BPBD,BNPB,MEDIA,APP,INS user
